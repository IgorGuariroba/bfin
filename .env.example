POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-use-strong-random-value
POSTGRES_DB=bfin
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
NODE_ENV=development
PORT=3000
CORS_ORIGIN=
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
MIGRATE_ON_BOOT=false
LOG_LEVEL=info
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30
DB_POOL_CONNECT_TIMEOUT=10
METRICS_TOKEN=
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
OIDC_ISSUER_URL=
OIDC_AUDIENCE=
ADMIN_EMAILS=

# MCP HTTP transport (OAuth 2.1 Resource Server)
# Set MCP_HTTP_ENABLED=true to register the plugin.
MCP_HTTP_ENABLED=false
MCP_HTTP_BASE_URL=
MCP_AUDIENCE_HTTP=
MCP_AUTH_SERVER_URL=
MCP_PROVISIONING_ALLOWED_EMAILS=
MCP_SESSION_STORE=memory
# Defaults to https://claude.ai,https://app.claude.com if empty.
# Add your own origins comma-separated.
MCP_ALLOWED_ORIGINS=https://api.bfincont.com.br
