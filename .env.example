POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-use-strong-random-value
POSTGRES_DB=bfin
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
NODE_ENV=development
PORT=3000
# CORS: with Next.js server-side proxy, browser never hits API directly.
# Leave empty unless you need direct browser access (e.g. webhooks).
CORS_ORIGIN=
# Rate limit: raised default because Next.js proxy multiplies requests per user action.
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=60000
MIGRATE_ON_BOOT=false
LOG_LEVEL=info
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30
DB_POOL_CONNECT_TIMEOUT=10
METRICS_TOKEN=
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Auth0 tenant — create an API identifier and set it as the audience.
# Example: https://bfin.us.auth0.com
OIDC_ISSUER_URL=
# Example: https://api.bfincont.com.br
OIDC_AUDIENCE=
ADMIN_EMAILS=

# Required when NODE_ENV=production. UUID of the isolated demo account
# used by the MCP directory submission. Seed via scripts/seed-demo-account.ts.
DEMO_ACCOUNT_ID=

# MCP HTTP transport (OAuth 2.1 Resource Server)
# Set MCP_HTTP_ENABLED=true to register the plugin.
MCP_HTTP_ENABLED=false
MCP_HTTP_BASE_URL=
MCP_AUDIENCE_HTTP=
MCP_AUTH_SERVER_URL=
MCP_PROVISIONING_ALLOWED_EMAILS=
MCP_SESSION_STORE=memory
# Defaults to https://claude.ai,https://app.claude.com if empty.
# Add your own origins comma-separated.
MCP_ALLOWED_ORIGINS=https://api.bfincont.com.br
