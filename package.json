{
  "name": "bfin",
  "version": "1.0.0",
  "description": "Financial Assistant API",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "docker compose up",
    "dev:down": "docker compose down",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "test": "docker compose -f docker-compose.test.yml up --build --abort-on-container-exit --exit-code-from api",
    "test:down": "docker compose -f docker-compose.test.yml down --remove-orphans",
    "test:vitest": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "mcp:delete-user": "tsx scripts/delete-mcp-user.ts",
    "mcp:audit-names": "tsx scripts/audit-mcp-names.ts",
    "mcp:audit-descriptions": "tsx scripts/audit-mcp-descriptions.ts",
    "mcp:check-doc-sync": "tsx scripts/check-mcp-doc-sync.ts",
    "mcp:check-branding": "tsx scripts/check-branding.ts",
    "mcp:check-submission": "tsx scripts/check-submission.ts",
    "demo:seed": "tsx scripts/seed-demo-account.ts",
    "demo:reset": "tsx scripts/reset-demo-account.ts",
    "test:hurl": "sh scripts/test-hurl.sh",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.2",
    "fastify-metrics": "^13.2.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.10.1",
    "marked": "^14.1.4",
    "openid-client": "^6.8.3",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^22.14.1",
    "@vitest/coverage-istanbul": "^3.2.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "testcontainers": "^11.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.1.1"
  },
  "overrides": {
    "esbuild": "^0.28.0",
    "protobufjs": "^7.5.5",
    "uuid": "^14.0.0"
  }
}
