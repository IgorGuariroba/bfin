# Auth0 Configuration for MCP HTTP+SSE OAuth 2.1
# This file contains NO secrets — only public identifiers and placeholders.
# Do NOT commit actual client secrets or management API credentials.

# Auth0 Tenant
AUTH0_DOMAIN=bfin.us.auth0.com
AUTH0_ISSUER_URL=https://bfin.us.auth0.com

# MCP API Identifier (audience)
MCP_AUDIENCE_HTTP=https://mcp.bfincont.com.br

# MCP HTTP Base URL (public-facing)
MCP_HTTP_BASE_URL=https://api.bfincont.com.br/mcp

# Dev Application (Regular Web Application) for obtaining test tokens
# Create this in Auth0 Dashboard > Applications > Create Application
AUTH0_DEV_CLIENT_ID=
AUTH0_DEV_CLIENT_SECRET=

# Auth0 Management API credentials (used by mcp:delete-user LGPD script)
# Create a Machine to Machine application authorized for the Auth0 Management API
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=

# Scopes configured in Auth0 API > Permissions
# accounts:read, accounts:write, account-members:read,
# categories:read, categories:write,
# transactions:read, transactions:write,
# debts:read, debts:write,
# goals:read, goals:write,
# daily-limit:read, daily-limit:write,
# projections:read
